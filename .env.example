# Database & API (/apps/api/.env)
# ================================
# Provided by Supabase or Local PostgreSQL deployment
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Direct URL needed universally for Prisma migrations in conjunction with connection pooling via Supabase
DIRECT_URL="postgresql://user:password@host:port/dbname"

# Keep this secure in production. Handles authentication token signing.
JWT_SECRET="generate_a_very_secure_string_here"

# The Express API Port
PORT=4000

# ================================
# Next.js Frontend (/apps/web/.env.local)
# ================================
# Map correctly to wherever the backend is hoisted
NEXT_PUBLIC_API_URL="https://your-production-api.com"
API_URL="https://your-production-api.com"

# ================================
# Playwright Worker Queue (/apps/worker/.env)
# ================================
# Upstream Redis container mapped automatically by BullMQ
REDIS_URL="redis://your-upstream-redis-instance"

# The worker utilizes the frontend's artifact saving layer
API_URL="https://your-production-api.com"
