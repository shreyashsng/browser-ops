# Database & API (/apps/api/.env)
# ================================
# Database - Supabase Recommended
# DATABASE_URL: Use the 'Transaction Mode' (port 6543) connection string
# DIRECT_URL: Use the 'Session Mode' (port 5432) connection string for migrations
DATABASE_URL="postgresql://postgres:[password]@db.[id].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[id].supabase.co:5432/postgres"

# Keep this secure in production. Handles authentication token signing.
JWT_SECRET="generate_a_very_secure_string_here"

# The Express API Port
PORT=4000

# ================================
# Next.js Frontend (/apps/web/.env.local)
# ================================
# Map correctly to wherever the backend is hoisted
NEXT_PUBLIC_API_URL="https://your-production-api.com"
API_URL="https://your-production-api.com"

# ================================
# Playwright Worker Queue (/apps/worker/.env)
# ================================
# Redis - Upstash Recommended
# REDIS_URL: Use the 'rediss://' protocol for Upstash/managed Redis (TLS)
REDIS_URL="rediss://default:[password]@[endpoint].upstash.io:[port]"

# The worker utilizes the frontend's artifact saving layer
API_URL="https://your-production-api.com"
